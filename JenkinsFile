pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Pulling latest code from Git...'
                checkout scm
            }
        }

        stage('Check Docker') {
            steps {
                sh 'docker --version'
            }
        }

        stage('Build API Server Image') {
            steps {
                sh 'docker build -t api-server:latest ./api-server'
            }
        }

        // stage('Build Frontend Image') {
        //     steps {
        //         sh '''
        //         docker build -t frontend:latest ./frontend \
        //           --build-arg NEXT_PUBLIC_API_URL=http://localhost:8080 \
        //           --build-arg NEXT_PUBLIC_SOCKET_URL=http://localhost:9001
        //         '''
        //     }
        // }

        stage('Build Reverse Proxy Image') {
            steps {
                sh 'docker build -t reverse-proxy:latest ./s3-reverse-proxy'
            }
        }

        stage('Verify Images') {
            steps {
                sh 'docker images | grep -E "api-server|reverse-proxy"'
            }
        }
    }

    post {
        success {
            echo 'All Docker images built successfully.'
        }
        failure {
            echo 'Build failed. Check logs.'
        }
    }
}