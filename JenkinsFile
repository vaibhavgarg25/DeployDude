pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'MINIKUBE_PROFILE', defaultValue: 'minikube', description: 'Minikube profile name running inside WSL/Linux.')
    booleanParam(name: 'ENABLE_INGRESS', defaultValue: true, description: 'Apply ingress with dynamic Minikube IP host rules.')
    booleanParam(name: 'WAIT_FOR_ROLLOUT', defaultValue: true, description: 'Wait until all deployments are ready.')
  }

  environment {
    K8S_NAMESPACE = 'deploydude'
    API_IMAGE = 'api-server'
    PROXY_IMAGE = 'reverse-proxy'
    FRONTEND_IMAGE = 'frontend'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Preflight') {
      steps {
        script {
          if (!isUnix()) {
            error('This pipeline must run on a Linux/WSL Jenkins agent because Minikube, Docker, and kubectl are running in WSL.')
          }
        }
        sh '''
          set -euo pipefail

          for bin in minikube kubectl docker sed awk; do
            command -v "$bin" >/dev/null 2>&1 || {
              echo "Missing dependency: $bin"
              exit 1
            }
          done

          minikube -p "$MINIKUBE_PROFILE" status >/dev/null 2>&1 || {
            echo "Minikube profile '$MINIKUBE_PROFILE' is not running. Starting..."
            minikube -p "$MINIKUBE_PROFILE" start
          }

          minikube -p "$MINIKUBE_PROFILE" addons enable ingress
        '''
      }
    }

    stage('Build Images In Minikube Docker') {
      steps {
        sh '''
          set -euo pipefail

          eval "$(minikube -p "$MINIKUBE_PROFILE" docker-env)"
          MINIKUBE_IP="$(minikube -p "$MINIKUBE_PROFILE" ip)"

          docker build -t "$API_IMAGE:latest" -t "$API_IMAGE:$BUILD_NUMBER" ./api-server
          docker build -t "$PROXY_IMAGE:latest" -t "$PROXY_IMAGE:$BUILD_NUMBER" ./s3-reverse-proxy
          docker build \
            --build-arg NEXT_PUBLIC_API_URL="http://api.$MINIKUBE_IP.nip.io" \
            --build-arg NEXT_PUBLIC_SOCKET_URL="http://socket.$MINIKUBE_IP.nip.io" \
            -t "$FRONTEND_IMAGE:latest" -t "$FRONTEND_IMAGE:$BUILD_NUMBER" ./frontend

          docker image ls "$API_IMAGE" --format 'table {{.Repository}}\t{{.Tag}}\t{{.ID}}' | head -n 5
          docker image ls "$PROXY_IMAGE" --format 'table {{.Repository}}\t{{.Tag}}\t{{.ID}}' | head -n 5
          docker image ls "$FRONTEND_IMAGE" --format 'table {{.Repository}}\t{{.Tag}}\t{{.ID}}' | head -n 5
        '''
      }
    }

    stage('Deploy To Kubernetes') {
      steps {
        sh '''
          set -euo pipefail

          kubectl apply -f ./k8s/namespace.yaml

          MINIKUBE_IP="$(minikube -p "$MINIKUBE_PROFILE" ip)"
          echo "Using Minikube IP: $MINIKUBE_IP"

          kubectl create secret generic api-server-env \
            --namespace "$K8S_NAMESPACE" \
            --from-env-file=./api-server/.env \
            --from-literal=PUBLIC_PROTOCOL=http \
            --from-literal=PUBLIC_BASE_DOMAIN="$MINIKUBE_IP.nip.io" \
            --from-literal=PUBLIC_PORT=80 \
            --dry-run=client -o yaml | kubectl apply -f -

          kubectl create secret generic reverse-proxy-env \
            --namespace "$K8S_NAMESPACE" \
            --from-env-file=./s3-reverse-proxy/.env \
            --dry-run=client -o yaml | kubectl apply -f -

          kubectl apply -f ./k8s/api-server-deployment.yaml
          kubectl apply -f ./k8s/api-server-service.yaml
          kubectl apply -f ./k8s/reverse-proxy-deployment.yaml
          kubectl apply -f ./k8s/reverse-proxy-service.yaml
          kubectl apply -f ./k8s/frontend-deployment.yaml
          kubectl apply -f ./k8s/frontend-service.yaml

          if [ "$ENABLE_INGRESS" = "true" ]; then
            sed -E "s/([0-9]{1,3}\.){3}[0-9]{1,3}/$MINIKUBE_IP/g" ./k8s/ingress.yaml | kubectl apply -f -
          fi

          if [ "$WAIT_FOR_ROLLOUT" = "true" ]; then
            kubectl rollout status deployment/api-server -n "$K8S_NAMESPACE" --timeout=180s
            kubectl rollout status deployment/reverse-proxy -n "$K8S_NAMESPACE" --timeout=180s
            kubectl rollout status deployment/frontend -n "$K8S_NAMESPACE" --timeout=180s
          fi
        '''
      }
    }

    stage('Deployment Summary') {
      steps {
        sh '''
          set -euo pipefail

          MINIKUBE_IP="$(minikube -p "$MINIKUBE_PROFILE" ip)"

          echo "========== Kubernetes Resources =========="
          kubectl get pods -n "$K8S_NAMESPACE" -o wide
          kubectl get svc -n "$K8S_NAMESPACE"
          kubectl get ingress -n "$K8S_NAMESPACE" || true

          echo "========== Endpoints =========="
          echo "Frontend endpoint: http://frontend.$MINIKUBE_IP.nip.io"
          echo "API endpoint:     http://api.$MINIKUBE_IP.nip.io"
          echo "Socket endpoint:  ws://socket.$MINIKUBE_IP.nip.io"
          echo "Project endpoint: http://<project-slug>.$MINIKUBE_IP.nip.io"

          echo "========== Port Forward For Frontend =========="
          echo "kubectl -n $K8S_NAMESPACE port-forward svc/frontend 3000:3000"
          echo "kubectl -n $K8S_NAMESPACE port-forward svc/api-server 8080:8080"
          echo "kubectl -n $K8S_NAMESPACE port-forward svc/api-server 9001:9001"
          echo "kubectl -n $K8S_NAMESPACE port-forward svc/reverse-proxy 8000:8000  # Optional: open deployed project URLs locally"
        '''
      }
    }
  }

  post {
    always {
      sh '''
        set +e
        echo "\n--- Recent API logs ---"
        kubectl logs -n "$K8S_NAMESPACE" deploy/api-server --tail=60
        echo "\n--- Recent Reverse Proxy logs ---"
        kubectl logs -n "$K8S_NAMESPACE" deploy/reverse-proxy --tail=60
        echo "\n--- Recent Frontend logs ---"
        kubectl logs -n "$K8S_NAMESPACE" deploy/frontend --tail=60
      '''
    }
  }
}
