pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Pulling latest code from Git...'
                checkout scm
            }
        }

        stage('Check Docker in WSL') {
            steps {
                bat 'wsl docker --version'
            }
        }

        stage('Build API Server Image') {
            steps {
                bat 'wsl bash -lc "cd /mnt/c/ProgramData/Jenkins/.jenkins/workspace/DeployOps-Build && docker build -t api-server:latest ./api-server"'
            }
        }

        stage('Build Frontend Image') {
            steps {
                bat 'wsl bash -lc "cd /mnt/c/ProgramData/Jenkins/.jenkins/workspace/DeployOps-Build && docker build -t frontend:latest ./frontend --build-arg NEXT_PUBLIC_API_URL=http://localhost:8080 --build-arg NEXT_PUBLIC_SOCKET_URL=http://localhost:9001"'
            }
        }

        stage('Build Reverse Proxy Image') {
            steps {
                bat 'wsl bash -lc "cd /mnt/c/ProgramData/Jenkins/.jenkins/workspace/DeployOps-Build && docker build -t reverse-proxy:latest ./reverse-proxy"'
            }
        }

        stage('Verify Images') {
            steps {
                bat 'wsl docker images | findstr "api-server frontend reverse-proxy"'
            }
        }
    }

    post {
        success {
            echo 'All Docker images built successfully.'
        }
        failure {
            echo 'Build failed. Check logs.'
        }
    }
}